# Soroban CrashLab Environment Configuration
# Copy this file to .env.local and fill in your values.

# Browser-exposed settings. Do not put secrets in NEXT_PUBLIC_* values.

# Backend API URL. Leave empty to use mock data for development.
# When you deploy the Rust backend, set this to its URL.
# Example: https://api.crashlab.example.com
NEXT_PUBLIC_API_URL=

# Application URL used for server-side fetches and permalinks.
# In development Next.js auto detects this. Set it for production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_ENABLE_MOCK_DATA=true

# Optional public integration identifiers
# NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Optional hosting analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Server-only settings. Keep these values out of client-side code.

# Optional API route backends
# RUNS_API_URL=
# ISSUES_API_URL=

# Optional notifications feed
# NOTIFICATIONS_FEED_ENABLED=true
# NOTIFICATIONS_FEED_URL=
# NOTIFICATIONS_API_URL=

# Optional metrics health check
# PROMETHEUS_ENDPOINT=http://localhost:9090
# PROMETHEUS_HEALTH_PATH=/-/healthy
# PROMETHEUS_TIMEOUT_MS=5000

# API rate limit for /api/* middleware
# CRASHLAB_API_RATE_LIMIT_WINDOW_MS=60000
# CRASHLAB_API_RATE_LIMIT_MAX_REQUESTS=120

# Local artifact storage
# CRASHLAB_ARTIFACT_DIR=
